# =======================================================================
#  FROST MILANO :: _headers  (Cloudflare Pages)
#
#  Tells browsers how long they may reuse a file before asking for it
#  again. The point: a repeat visitor should NOT re-download ~24 MB of
#  video every time they open the site.
#
#  Cloudflare reads this file at deploy time and applies it to responses.
#  It is not served as a page.
#
#  ⚠️  IMPORTANT — HOW MATCHING ACTUALLY WORKS
#  Cloudflare Pages APPENDS the headers from every rule that matches a
#  request. It does NOT override. So if /* sets Cache-Control and /css/*
#  also sets Cache-Control, a request for /css/style.css gets BOTH,
#  concatenated into one header:
#
#      Cache-Control: public, max-age=0, must-revalidate, public, max-age=3600
#
#  The most restrictive directive wins, so the max-age=0 silently beats
#  the real rule and nothing gets cached. This file was broken exactly
#  that way once — don't reintroduce it.
#
#  RULE: only ONE rule may set Cache-Control for any given path.
#  The catch-all below therefore sets security headers ONLY.
# =======================================================================


# ---------- EVERYTHING: security headers only, never Cache-Control ----------
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin


# ---------- HTML ----------
# Intentionally absent. Cloudflare Pages already defaults HTML to
# "public, max-age=0, must-revalidate", which is what we want: the page
# always revalidates so nobody lands on a stale entry point. Adding a rule
# here would collide with the asset rules per the warning above.


# ---------- CSS + JS ----------
# These change whenever the site is edited, and the filenames never change
# (no content hash), so a long cache would serve stale styles after a
# deploy. One hour, then stale-while-revalidate lets the browser paint
# instantly from cache while it quietly fetches the update in the
# background. Edits reach everyone within the hour, worst case.
/css/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/js/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400


# ---------- IMAGES ----------
# Small and rarely touched. 30 days.
/images/*
  Cache-Control: public, max-age=2592000


# ---------- VIDEO ----------
# The whole reason this file exists. Each clip is several MB, so caching
# these is where essentially all the bandwidth savings come from — a
# returning visitor re-downloads nothing.
#
# 30 days, deliberately NOT "immutable". See the note below.
/video/*
  Cache-Control: public, max-age=2592000


# =======================================================================
#  IF YOU REPLACE A CLIP
#
#  Caching is a promise: you've told browsers "this file is good for 30
#  days." If you overwrite video/clip-01.mp4 with different footage, a
#  visitor who already has the old one may keep seeing it for up to a
#  month. Deleting your own cache won't fix it for them.
#
#  The fix is to change the FILENAME, which makes it a different file as
#  far as every cache on earth is concerned:
#
#      video/clip-01.mp4   ->   video/clip-01-v2.mp4
#
#  ...then update the matching <source src="..."> in index.html. New name,
#  no cached copy, everyone gets it immediately.
#
#  This is also why max-age is 30 days and not a year with "immutable".
#  A year would save marginally more bandwidth and turn every forgotten
#  rename into a months-long problem. If you ever move to hashed
#  filenames (clip-01.a3f9c2.mp4) that changes — then immutable is safe,
#  because the name always changes when the content does.
# =======================================================================
