# Normalize text files to LF in the repo, regardless of what Windows does
# locally. Without this, editing on a different machine can show up as a
# whole-file diff with zero real changes.
* text=auto eol=lf

# Binaries — never touch these
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary
*.mp4 binary
*.webm binary
*.mov binary
